                      "textPt":  "Olá. Como está?",
                      "textDa":  "Hej. Hvordan har du det?",
                      "grammarDa":  "Está kommer af estar."
                  },
                  {
                      "speaker":  "A",
                      "textPt":  "Estou bem, obrigado.",
                      "textDa":  "Jeg har det godt, tak.",
                      "grammarDa":  "Estou bruges om en midlertidig tilstand."
                  },
                  {
                      "speaker":  "B",
                      "textPt":  "Hoje praticamos uma conversa curta.",
                      "textDa":  "I dag øver vi en kort samtale.",
                      "grammarDa":  "Praticamos betyder vi øver."
                  },
                  {
                      "speaker":  "A",
                      "textPt":  "Tenho uma pergunta.",
                      "textDa":  "Jeg har et spørgsmål.",
                      "grammarDa":  "Tenho kommer af ter."
                  },
                  {
                      "speaker":  "B",
                      "textPt":  "Claro, diga devagar.",
                      "textDa":  "Selvfølgelig, sig det langsomt.",
                      "grammarDa":  "Diga er en høflig opfordring."
                  },
                  {
                      "speaker":  "A",
                      "textPt":  "Como se diz isto em português?",
                      "textDa":  "Hvordan siger man dette på portugisisk?",
                      "grammarDa":  "Como se diz bruges til at spørge om ord."
                  },
                  {
                      "speaker":  "B",
                      "textPt":  "Dizemos uma frase curta.",
                      "textDa":  "Vi siger en kort sætning.",
                      "grammarDa":  "Uma frase curta betyder en kort sætning."
                  },
                  {
                      "speaker":  "A",
                      "textPt":  "Repito a frase.",
                      "textDa":  "Jeg gentager sætningen.",
                      "grammarDa":  "Repito betyder jeg gentager."
                  },
                  {
                      "speaker":  "B",
                      "textPt":  "Muito bem.",
                      "textDa":  "Meget fint.",
                      "grammarDa":  "Muito bem er positiv feedback."
                  },
                  {
                      "speaker":  "A",
                      "textPt":  "Obrigado pela ajuda.",
                      "textDa":  "Tak for hjælpen.",
                      "grammarDa":  "Obrigado bruges af en mand; obrigada af en kvinde."
                  },
                  {
                      "speaker":  "B",
